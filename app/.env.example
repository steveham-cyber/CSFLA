# ============================================================
# CSFLA Research Application — Environment Variables
# Copy to .env for local development. NEVER commit .env.
# In Azure, these are set as App Service environment variables.
# ============================================================

# Azure Entra ID (OAuth)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-registration-client-id
# AZURE_CLIENT_SECRET — only for local dev. In Azure, use Managed Identity (no secret needed).
AZURE_CLIENT_SECRET=

# Azure Key Vault
AZURE_KEY_VAULT_URL=https://csfleak-research-kv.vault.azure.net/
AZURE_KEY_VAULT_KEY_NAME=pseudonymisation-key

# Database (Azure PostgreSQL)
# In Azure: DB_PASSWORD is not used — Managed Identity token auth is used instead.
# For local dev: set DB_PASSWORD to your local PostgreSQL password.
DB_HOST=csfleak-research-db.postgres.database.azure.com
DB_PORT=5432
DB_NAME=csfleak_research
DB_USER=csfleak_app
DB_PASSWORD=

# Application
APP_ENV=development
SECRET_KEY=change-this-to-a-random-string-for-local-dev
ALLOWED_ORIGINS=http://localhost:3000

# Anthropic (Claude API) — only set once DPA with Anthropic is in place
# ANTHROPIC_API_KEY=
